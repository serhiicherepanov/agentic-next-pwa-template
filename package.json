{
  "name": "agentic-next-pwa-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "node scripts/run-with-env.mjs .env.dev -- next dev -p 3000",
    "dev:deps": "pnpm docker:volumes:local && docker compose --env-file .env.dev -f docker-compose.dev.yml up -d --wait",
    "dev:deps:down": "docker compose --env-file .env.dev -f docker-compose.dev.yml down",
    "dev:deps:reset": "docker compose --env-file .env.dev -f docker-compose.dev.yml down && (docker volume rm -f agentic-template-local_pgdata || true) && pnpm docker:volumes:local",
    "dev:deps:e2e": "pnpm docker:volumes:local && docker compose --env-file .env.e2e -f docker-compose.dev.yml up -d --wait",
    "dev:deps:e2e:down": "docker compose --env-file .env.e2e -f docker-compose.dev.yml down",
    "docker:volumes:local": "bash scripts/ensure-docker-data-volumes.sh local",
    "docker:volumes:prod": "bash scripts/ensure-docker-data-volumes.sh prod",
    "prod:up": "pnpm docker:volumes:prod && docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build",
    "prod:down": "docker compose --env-file .env.prod -f docker-compose.prod.yml down",
    "prod:build": "docker compose --env-file .env.prod -f docker-compose.prod.yml build",
    "prod:ps": "docker compose --env-file .env.prod -f docker-compose.prod.yml ps",
    "prod:logs": "docker compose --env-file .env.prod -f docker-compose.prod.yml logs -f --tail=200",
    "prod:migrate": "docker compose --env-file .env.prod -f docker-compose.prod.yml exec -T app pnpm db:migrate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci:install": "pnpm install --frozen-lockfile",
    "test:ci:pre": "pnpm exec playwright install --with-deps",
    "test:ci:unit": "pnpm test",
    "test:ci:e2e": "pnpm e2e --project=mobile-portrait --project=tablet",
    "test:ci": "pnpm test:ci:unit && pnpm test:ci:e2e",
    "e2e": "node scripts/run-e2e.mjs",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "verify:ci": "pnpm typecheck && pnpm test && pnpm lint && pnpm build",
    "db:generate": "node scripts/run-with-env.mjs .env.dev .env.e2e -- prisma generate",
    "db:migrate": "node scripts/run-with-env.mjs .env.dev .env.e2e -- prisma migrate deploy",
    "db:migrate:dev": "node scripts/run-with-env.mjs .env.dev .env.e2e -- prisma migrate dev",
    "db:push": "node scripts/run-with-env.mjs .env.dev .env.e2e -- prisma db push",
    "db:studio": "node scripts/run-with-env.mjs .env.dev .env.e2e -- prisma studio",
    "postinstall": "prisma generate",
    "prepare": "husky || true"
  },
  "pnpm": {
    "allowBuilds": {
      "@prisma/client": true,
      "@prisma/engines": true,
      "esbuild": true,
      "prisma": true,
      "sharp": true,
      "unrs-resolver": true
    }
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-slot": "^1.2.3",
    "@scalar/api-reference-react": "^0.9.41",
    "@tanstack/react-query": "^5.60.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "15.5.15",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-error-boundary": "^5.0.0",
    "react-hook-form": "^7.53.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.0",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
