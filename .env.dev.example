# Local development: host `pnpm dev` + Postgres from the default docker-compose.yml.
DATABASE_URL="postgresql://agentic:agentic@localhost:55432/agentic?schema=public"
POSTGRES_USER=agentic
POSTGRES_PASSWORD=agentic
POSTGRES_DB=agentic
POSTGRES_PORT=55432

PORT=3000
LOG_LEVEL=info

# Enable only for app-like projects that should be installable.
# PWA_ENABLED=1

# Playwright can override these when reusing a running dev server.
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# PLAYWRIGHT_TEST_PORT=3000
