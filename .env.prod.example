POSTGRES_USER=agentic
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=agentic
DATABASE_URL="postgresql://agentic:replace-with-a-long-random-password@db:5432/agentic?schema=public"

APP_HTTP_PORT=3080
APP_AUTO_MIGRATE=1
LOG_LEVEL=info

# Database driver. Use `pg` (default) for the local/Docker Postgres engine,
# or `neon` when deploying to Vercel/edge with a Neon serverless connection.
DATABASE_DRIVER=pg

# Enable only for app-like products: dashboards, admin panels, mobile tools,
# or stores that intentionally support installable/PWA behavior.
# PWA_ENABLED=1

# Dokploy only: host bind-mount root and external Traefik network.
APP_HOST_DATA_ROOT=/opt/agentic-next-pwa-template
DOKPLOY_NETWORK=dokploy-network
